#!/data/data/com.termux/files/usr/bin/bash

DEFAULT_DISTRO="debian"

if ! command -v proot-distro >/dev/null 2>&1; then
  echo "sudo: proot-distro not installed."
  exit 1
fi

# Already inside proot
if [ -n "$PROOT_DISTRIBUTION" ]; then
  exec "$@"
fi

# sudo with no args = open root shell
if [ $# -eq 0 ]; then
  exec proot-distro login "$DEFAULT_DISTRO" --shared-tmp
fi

# run command in rootfs
exec proot-distro login "$DEFAULT_DISTRO" --shared-tmp -- "$@"

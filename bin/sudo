#!/data/data/com.termux/files/usr/bin/bash

# If already root, sudo should just run the command
if [ "$(id -u 2>/dev/null)" = "0" ]; then
  exec "$@"
fi

DEFAULT_DISTRO="debian"

# If proot-distro missing
if ! command -v proot-distro >/dev/null 2>&1; then
  echo "❌ proot-distro not installed."
  exit 1
fi

# If no command given, open root shell
if [ $# -eq 0 ]; then
  exec proot-distro login "$DEFAULT_DISTRO" --shared-tmp
fi

exec proot-distro login "$DEFAULT_DISTRO" --shared-tmp -- "$@"

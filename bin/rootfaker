#!/data/data/com.termux/files/usr/bin/bash

set -e

VERSION="3.0.0-arch"

CFG_DIR="$PREFIX/etc/rootfaker"
ACTIVE_PROFILE_FILE="$CFG_DIR/active_profile"

BASE_DIR="$HOME/.rootfaker"
PROFILES_DIR="$BASE_DIR/profiles"

mkdir -p "$CFG_DIR"
mkdir -p "$PROFILES_DIR"

# =============================
# Output Helpers
# =============================

info()    { echo "[INFO] $1"; }
success() { echo "[SUCCESS] $1"; }
error()   { echo "[ERROR] $1"; }
die()     { error "$1"; exit 1; }

# =============================
# Utility Functions
# =============================

validate_profile_name() {
  [[ "$1" =~ ^[a-zA-Z0-9_-]+$ ]] || die "Invalid profile name."
}

get_active_profile() {
  [ -f "$ACTIVE_PROFILE_FILE" ] && cat "$ACTIVE_PROFILE_FILE"
}

is_installed_distro() {
  [ -d "$PREFIX/var/lib/proot-distro/installed-rootfs/$1" ]
}

ensure_profile_dirs() {
  mkdir -p "$PROFILES_DIR/$1/home"
  mkdir -p "$PROFILES_DIR/$1/workspace"
}

auto_install_if_missing() {
  if ! is_installed_distro "$1"; then
    info "Installing distro '$1'..."
    proot-distro install "$1"
  fi
}

# =============================
# Commands
# =============================

cmd_help() {
  echo "RootFaker v$VERSION"
  echo ""
  echo "Commands:"
  echo "  rootfaker root"
  echo "  rootfaker profile create <name> <distro>"
  echo "  rootfaker profile list"
  echo "  rootfaker profile switch <name>"
  echo "  rootfaker profile show"
  echo "  rootfaker profile delete <name>"
  echo "  rootfaker doctor"
  echo "  rootfaker --version"
}

cmd_doctor() {
  echo "RootFaker Doctor"
  echo "-----------------"

  command -v proot-distro >/dev/null \
    && success "proot-distro found" \
    || error "proot-distro missing"

  [ -d "$PROFILES_DIR" ] \
    && success "Profiles directory OK" \
    || error "Profiles directory missing"

  ACTIVE=$(get_active_profile)
  [ -z "$ACTIVE" ] \
    && info "No active profile" \
    || success "Active profile: $ACTIVE"
}

cmd_profile() {
  case "$1" in

    create)
      validate_profile_name "$2"
      [ -z "$3" ] && die "Usage: profile create <name> <distro>"

      PROFILE_PATH="$PROFILES_DIR/$2"
      [ -d "$PROFILE_PATH" ] && die "Profile already exists."

      mkdir -p "$PROFILE_PATH"
      ensure_profile_dirs "$2"
      echo "$3" > "$PROFILE_PATH/distro"

      success "Profile '$2' created."
      ;;

    list)
      echo "Profiles:"
      ls "$PROFILES_DIR" 2>/dev/null || true
      ;;

    switch)
      validate_profile_name "$2"
      PROFILE_PATH="$PROFILES_DIR/$2"
      [ ! -d "$PROFILE_PATH" ] && die "Profile does not exist."

      echo "$2" > "$ACTIVE_PROFILE_FILE"
      success "Active profile set to '$2'"
      ;;

    show)
      ACTIVE=$(get_active_profile)
      [ -z "$ACTIVE" ] && die "No active profile."

      DISTRO=$(cat "$PROFILES_DIR/$ACTIVE/distro")
      echo "Active profile: $ACTIVE"
      echo "Distro: $DISTRO"
      ;;

    delete)
      validate_profile_name "$2"
      PROFILE_PATH="$PROFILES_DIR/$2"
      [ ! -d "$PROFILE_PATH" ] && die "Profile does not exist."

      ACTIVE=$(get_active_profile)
      [ "$ACTIVE" = "$2" ] && die "Cannot delete active profile."

      case "$PROFILE_PATH" in
        "$PROFILES_DIR"/*) ;;
        *) die "Unsafe delete blocked." ;;
      esac

      rm -rf "$PROFILE_PATH"
      success "Profile '$2' deleted."
      ;;

    *)
      die "Unknown profile command."
      ;;
  esac
}

cmd_root() {
  ACTIVE=$(get_active_profile)
  [ -z "$ACTIVE" ] && die "No active profile."

  PROFILE_PATH="$PROFILES_DIR/$ACTIVE"
  [ ! -f "$PROFILE_PATH/distro" ] && die "Invalid profile."

  DISTRO=$(cat "$PROFILE_PATH/distro")

  ensure_profile_dirs "$ACTIVE"
  auto_install_if_missing "$DISTRO"

  exec proot-distro login "$DISTRO" \
    --bind "$PROFILE_PATH/home:/root" \
    --bind "$PROFILE_PATH/workspace:/workspace"
}

# =============================
# Main Dispatcher
# =============================

main() {

  case "$1" in
    help|--help) cmd_help ;;
    --version) echo "RootFaker v$VERSION" ;;
    doctor) cmd_doctor ;;
    profile) shift; cmd_profile "$@" ;;
    root|"") cmd_root ;;
    *) die "Unknown command." ;;
  esac
}

main "$@"

#!/data/data/com.termux/files/usr/bin/bash

if ! command -v proot-distro >/dev/null 2>&1; then
  pkg update -y
  pkg install -y proot proot-distro
fi

clear
echo "RootFaker Manager"
echo "-----------------"
echo "1) Install distro"
echo "2) Login distro"
echo "3) List distros"
echo "4) Remove distro"
echo "5) Exit"
echo ""

read -p "Choose: " C

case "$C" in
  1) proot-distro list; read -p "Distro: " D; proot-distro install "$D" ;;
  2) read -p "Distro: " D; exec proot-distro login "$D" --shared-tmp ;;
  3) proot-distro list ;;
  4) read -p "Distro: " D; proot-distro remove "$D" ;;
  5) exit 0 ;;
  *) echo "Invalid choice" ;;
esac
